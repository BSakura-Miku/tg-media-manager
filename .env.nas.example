# Copy this file to .env beside docker-compose.nas.yml on the NAS.
# Do not commit the populated .env file.
TG_MEDIA_MANAGER_IMAGE=tg-media-manager:1.5.6-amd64
APP_PASSWORD=replace-with-a-strong-login-password
APP_SECRET=replace-with-output-of-openssl-rand-hex-32
APP_LOCAL_ONLY=false
APP_COOKIE_SECURE=false
APP_SESSION_TTL_SECONDS=43200
MODEL_ALLOW_HTTP_DOWNLOADS=false
MODEL_REQUIRE_SHA256_CUSTOM=true
GENERATE_TIMED_SUBTITLES=true
TRANSCRIPT_ENGINE=stable-faster-whisper
WHISPER_MODEL=medium
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_VAD_THRESHOLD=0.5
WHISPER_MIN_SILENCE_MS=500
WHISPER_NO_SPEECH_THRESHOLD=0.6
WHISPER_LOG_PROB_THRESHOLD=-1.0
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
SUBTITLE_MAX_CHARS=24
SUBTITLE_MAX_SECONDS=7
SUBTITLE_MIN_SECONDS=0.8
SUBTITLE_MAX_GAP=0.8
